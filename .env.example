# Chave de API do OpenRouter (Obrigatória)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MODEL_NAME=openai/gpt-3.5-turbo # Você pode mudar para qualquer um no OpenRouter

# Configurações de Segurança da Alexa (Opcionais, mas altamente recomendadas)
# ALEXA_SKILL_ID bloqueia chamadas que não venham da sua Skill oficial
ALEXA_SKILL_ID=amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ALEXA_SECRET_TOKEN exige que a URL do webhook tenha ?token=sua_senha_aqui
ALEXA_SECRET_TOKEN=UmaSenhaMuitoComplexa123

# Outras configs
DEBUG=True