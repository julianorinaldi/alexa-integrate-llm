{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["welcomeData"],
    "item": {
      "type": "Container",
      "width": "100vw",
      "height": "100vh",
      "background": {
        "type": "LinearGradient",
        "angle": 135,
        "colorRange": ["#020817", "#0c1a35", "#071428"]
      },
      "justifyContent": "center",
      "alignItems": "center",
      "items": [
        {
          "type": "Container",
          "width": "80vw",
          "alignItems": "center",
          "items": [
            {
              "type": "Text",
              "text": "◈",
              "fontSize": "10vw",
              "color": "#38bdf8",
              "textAlign": "center"
            },
            {
              "type": "Text",
              "text": "${welcomeData.header}",
              "fontSize": "7vw",
              "fontWeight": "300",
              "color": "#f1f5f9",
              "textAlign": "center",
              "paddingTop": "3vh",
              "letterSpacing": "0.3vw"
            },
            {
              "type": "Frame",
              "width": "15vw",
              "height": "2px",
              "backgroundColor": "#38bdf8",
              "marginTop": "2vh",
              "marginBottom": "3vh"
            },
            {
              "type": "Text",
              "text": "${welcomeData.text}",
              "fontSize": "3.5vw",
              "color": "#94a3b8",
              "textAlign": "center",
              "lineHeight": 1.5
            }
          ]
        }
      ]
    }
  }
}
