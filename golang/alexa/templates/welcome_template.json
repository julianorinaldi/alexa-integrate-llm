{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "mainTemplate": {
    "parameters": [
      "welcomeData"
    ],
    "item": [
      {
        "type": "AlexaHeadline",
        "primaryText": "${welcomeData.header}",
        "secondaryText": "${welcomeData.text}",
        "backgroundImageSource": "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=1080",
        "backgroundColor": "transparent",
        "theme": "dark"
      }
    ]
  }
}
