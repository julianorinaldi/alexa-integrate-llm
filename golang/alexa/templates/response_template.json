{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["chatData"],
    "item": {
      "type": "Container",
      "width": "100vw",
      "height": "100vh",
      "background": {
        "type": "LinearGradient",
        "angle": 160,
        "colorRange": ["#020817", "#0d1b2e", "#0a0f1e"]
      },
      "items": [
        {
          "type": "ScrollView",
          "width": "100vw",
          "height": "100vh",
          "item": {
            "type": "Container",
            "paddingTop": "4vh",
            "paddingBottom": "4vh",
            "paddingLeft": "6vw",
            "paddingRight": "6vw",
            "items": [
              {
                "type": "Text",
                "text": "▶ PERGUNTA",
                "color": "#38bdf8",
                "fontSize": "2.5vw",
                "fontWeight": "700",
                "letterSpacing": "0.2vw"
              },
              {
                "type": "Frame",
                "marginTop": "1.5vh",
                "marginBottom": "4vh",
                "paddingLeft": "3vw",
                "paddingTop": "2vh",
                "paddingBottom": "2vh",
                "paddingRight": "3vw",
                "borderLeftWidth": "3px",
                "borderLeftColor": "#38bdf8",
                "backgroundColor": "rgba(56, 189, 248, 0.06)",
                "borderRadius": "0.5vw",
                "item": {
                  "type": "Text",
                  "text": "${chatData.question}",
                  "fontSize": "4vw",
                  "color": "#e2e8f0",
                  "lineHeight": 1.4
                }
              },
              {
                "type": "Text",
                "text": "◆ RESPOSTA",
                "color": "#a78bfa",
                "fontSize": "2.5vw",
                "fontWeight": "700",
                "letterSpacing": "0.2vw"
              },
              {
                "type": "Frame",
                "marginTop": "1.5vh",
                "paddingLeft": "3vw",
                "paddingTop": "2.5vh",
                "paddingBottom": "2.5vh",
                "paddingRight": "3vw",
                "borderLeftWidth": "3px",
                "borderLeftColor": "#a78bfa",
                "backgroundColor": "rgba(167, 139, 250, 0.06)",
                "borderRadius": "0.5vw",
                "item": {
                  "type": "Text",
                  "text": "${chatData.answer}",
                  "fontSize": "4.2vw",
                  "color": "#f1f5f9",
                  "lineHeight": 1.5
                }
              }
            ]
          }
        }
      ]
    }
  }
}
